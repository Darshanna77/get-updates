# Copy this file to .env and fill in your values
# For GitHub Actions, these should be added as secrets

# Your Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram Chat IDs (comma-separated for multiple users)
# Examples:
# Single user: 123456789
# Multiple users: 123456789,987654321,555555555
TELEGRAM_CHAT_IDS=your_chat_id_here

# Optional: Database path (defaults to pulse.db in current directory)
# DB_PATH=pulse.db
